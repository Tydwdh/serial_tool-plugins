{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hardware-workbench.local/schemas/registry.schema.json",
  "title": "Hardware Workbench plugin marketplace registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updated", "plugins"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "registry 格式版本号，破坏性变更时 +1"
    },
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 最近更新时间"
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pluginEntry"
      }
    }
  },
  "$defs": {
    "pluginEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version", "api_version", "description", "download_url", "sha256", "size"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "api_version": {
          "type": "string",
          "enum": ["0.1"]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string"
        },
        "homepage": {
          "type": "string",
          "pattern": "^https?://"
        },
        "repository": {
          "type": "string",
          "pattern": "^https?://"
        },
        "license": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "download_url": {
          "type": "string",
          "pattern": "^https://",
          "description": "必须 https。指向 zip 包"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "zip 包的 SHA256 校验值"
        },
        "size": {
          "type": "integer",
          "minimum": 0,
          "description": "zip 包字节数"
        },
        "published": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
